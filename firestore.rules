rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isStartupAdminOf(startupId) {
      return isSignedIn() &&
        myProfile().role == 'startup_admin' &&
        myProfile().startupId == startupId;
    }

    // ---------------------------------------------------------------
    // users/{uid}
    // ---------------------------------------------------------------
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) &&
        // role can never be changed by the client after signup
        request.resource.data.role == resource.data.role;
      allow delete: if false;
    }

    // ---------------------------------------------------------------
    // startups/{startupId}
    // ---------------------------------------------------------------
    match /startups/{startupId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() &&
        myProfile().role == 'startup_admin' &&
        request.resource.data.adminUids.hasOnly([request.auth.uid]) &&
        request.resource.data.verificationStatus == 'pending';

      // Owner can edit their own startup, but can never verify themselves.
      allow update: if isStartupAdminOf(startupId) &&
        request.resource.data.verificationStatus == resource.data.verificationStatus;

      allow delete: if false;
    }

    // ---------------------------------------------------------------
    // opportunities/{opportunityId}
    // ---------------------------------------------------------------
    match /opportunities/{opportunityId} {
      allow read: if isSignedIn();

      allow create: if isStartupAdminOf(request.resource.data.startupId) &&
        get(/databases/$(database)/documents/startups/$(request.resource.data.startupId))
          .data.verificationStatus == 'verified';

      allow update, delete: if isStartupAdminOf(resource.data.startupId);
    }
  }
}
